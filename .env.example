# RCFlow Configuration

# Server
RCFLOW_HOST=0.0.0.0
RCFLOW_PORT=8765
RCFLOW_API_KEY=your-api-key-here

# SSL/TLS — set both to serve over HTTPS/WSS
# SSL_CERTFILE=/path/to/cert.pem
# SSL_KEYFILE=/path/to/key.pem

# Database
DATABASE_URL=postgresql+asyncpg://rcflow:password@localhost:5432/rcflow

# LLM Provider: "anthropic" (direct API) or "bedrock" (AWS Bedrock)
LLM_PROVIDER=anthropic

# Anthropic LLM (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# AWS Bedrock (used when LLM_PROVIDER=bedrock)
# ANTHROPIC_MODEL should use Bedrock model IDs, e.g. anthropic.claude-sonnet-4-20250514-v1:0
# AWS credentials are optional if using IAM roles, instance profiles, or ~/.aws/credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# STT (Speech-to-Text)
STT_PROVIDER=wispr_flow
STT_API_KEY=your-wispr-flow-key-here

# TTS (Text-to-Speech)
TTS_PROVIDER=none
TTS_API_KEY=

# Projects directory (absolute path; ~ is expanded at startup)
# Set this explicitly when running as a different user (e.g. root via systemd)
PROJECTS_DIR=~/Projects

# Codex CLI (OpenAI Codex)
CODEX_API_KEY=

# Tools
TOOLS_DIR=./tools

# Tool Management
TOOL_AUTO_UPDATE=true
TOOL_UPDATE_INTERVAL_HOURS=6

# Logging
LOG_LEVEL=INFO
